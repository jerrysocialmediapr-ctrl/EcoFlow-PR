# ============================================
# VARIABLES DE ENTORNO - EcoFlow PR
# ============================================
# Copia este archivo a .env.local (para desarrollo local)
# En Vercel, configura estas variables en: Settings > Environment Variables
# ============================================

# ============================================
# 1. GOOGLE APPS SCRIPT (GAS) - REQUERIDO
# ============================================
# Token de autenticación para enviar datos a Google Sheets
# Se valida en cada request a /api/lead
# Valor debe ser: "PS-CRM-2024-SECURE-TOKEN"
GAS_TOKEN="PS-CRM-2024-SECURE-TOKEN"

# ============================================
# 2. MODO DE PRUEBA - REQUERIDO
# ============================================
# true = Modo de prueba (redirige emails a TEST_EMAIL_RECIPIENT)
# false = Modo producción (envía a email real del cliente)
# Por defecto: true (SEGURO)
TEST_MODE="true"

# ============================================
# 3. EMAIL DE PRUEBA - REQUERIDO SI TEST_MODE=true
# ============================================
# Email donde llegan los correos de prueba
# Reemplaza con tu email personal
TEST_EMAIL_RECIPIENT="jerrypowersolar@gmail.com"

# ============================================
# 4. URL BASE PÚBLICA - REQUERIDO
# ============================================
# Esta URL se usa para generar links de confirmación en los emails
# Los clientes hacen clic en estos links para confirmar o rechazar la cotización
#
# OPCIONES (elige una):
#
# OPCIÓN A - URL PROVISIONAL (Vercel):
# URL: https://jerry.ecoflow-pr.com
# Usar para: Pruebas, desarrollo, antes de dominio personalizado
# Ventaja: Se auto-actualiza con cada deploy
# Desventaja: No es profesional para clientes reales
#
# OPCIÓN B - URL OFICIAL (Dominio personalizado):
# URL: https://jerry.ecoflow-pr.com
# Usar para: Producción, clientes reales
# Ventaja: Profesional, dominio personalizado
# Desventaja: Requiere configuración de DNS en Vercel
#
# INSTRUCCIONES PARA CONFIGURAR DOMINIO:
# 1. Ve a Vercel Dashboard > Tu Proyecto
# 2. Settings > Domains
# 3. Agrega dominio: jerry.ecoflow-pr.com
# 4. Sigue instrucciones de DNS del registrador
# 5. Espera 24-48 horas para propagación
#
# CONFIGURA UNO DE ESTOS:
PUBLIC_BASE_URL="https://jerry.ecoflow-pr.com"
# PUBLIC_BASE_URL="https://jerry.ecoflow-pr.com"

# ============================================
# 5. MODO ACTUAL - INFORMACIÓN
# ============================================
# Indica qué modo estás usando actualmente
# Úsalo solo para documentación/logs
# Valores: "provisional" | "official"
DEPLOYMENT_MODE="provisional"

# ============================================
# 6. INFORMACIÓN DEL CONSULTANTE - OPCIONAL
# ============================================
# Datos del consultor que aparecen en cotizaciones
CONSULTANT_NAME="Jerry Encarnación"
CONSULTANT_PHONE="787-628-1344"
CONSULTANT_EMAIL="info@powersolarprr.com"

# ============================================
# 7. INFORMACIÓN DE LA EMPRESA - OPCIONAL
# ============================================
# Datos que aparecen en PDFs y emails
COMPANY_NAME="Power Solar"
COMPANY_FULLNAME="Power Solar LLC"
COMPANY_LOCATION="Puerto Rico"
COMPANY_WEBSITE="https://jerry.ecoflow-pr.com"

# ============================================
# CHECKLIST DE CONFIGURACIÓN
# ============================================
# ✅ GAS_TOKEN: Valor correcto y seguro
# ✅ TEST_MODE: true para desarrollo, false para producción
# ✅ TEST_EMAIL_RECIPIENT: Tu email para recibir pruebas
# ✅ PUBLIC_BASE_URL: URL correcta (sin barra final)
# ✅ Todas las variables sin espacios antes/después del =
# ✅ Sin comillas extras en los valores
#
# COMO AGREGAR A VERCEL:
# 1. Dashboard > Proyecto > Settings > Environment Variables
# 2. Copia cada línea (sin el #)
# 3. Pega KEY=VALUE
# 4. Haz clic en "Add"
# 5. Redeploy el proyecto (auto o manual)
#
# VERIFICAR EN VERCEL:
# 1. Deployments > Click en el deploy más reciente
# 2. Logs > Busca "[CONFIG]" para ver valores cargados
# 3. Si ves errores, revisa las variables
