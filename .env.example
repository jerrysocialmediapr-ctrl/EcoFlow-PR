# ============================================
# VARIABLES DE ENTORNO - EcoFlow PR
# ============================================
# Copia este archivo a .env.local (para desarrollo local).
# En Vercel: Settings > Environment Variables.
# Nunca publiques valores reales ni uses prefijos VITE_ para secretos.

# Google Apps Script - requerido
GAS_URL=""
GAS_TOKEN=""

# Modo de prueba
TEST_MODE="true"
TEST_EMAIL_RECIPIENT="jerrypowersolar@gmail.com"

# URL pública oficial usada en enlaces de confirmación
PUBLIC_BASE_URL="https://jerry.ecoflow-pr.com"
DEPLOYMENT_MODE="official"

# Callback instantáneo al CRM para email y Web Push del administrador.
# El handler corrige automáticamente cualquier alias antiguo al dominio oficial.
# Mantén el token exclusivamente en el servidor; Vercel OIDC también se reenvía cuando está disponible.
CRM_PUSH_URL="https://crm.powersolarprr.com/api/push"
LEAD_PUSH_WEBHOOK_TOKEN=""

# Información del consultante
CONSULTANT_NAME="Jerry Encarnación"
CONSULTANT_PHONE="787-628-1344"
CONSULTANT_EMAIL="info@powersolarprr.com"

# Información de la empresa
COMPANY_NAME="Power Solar"
COMPANY_FULLNAME="Power Solar LLC"
COMPANY_LOCATION="Puerto Rico"
COMPANY_WEBSITE="https://jerry.ecoflow-pr.com"

# Verificación de la conexión sin crear leads:
# https://jerry.ecoflow-pr.com/api/lead?action=crm-health
