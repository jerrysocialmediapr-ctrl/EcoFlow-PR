# EcoFlow PR — plantilla segura de variables
# Este archivo solo documenta nombres. Nunca coloques valores reales en Git.

# Google Apps Script
GAS_URL=
GAS_TOKEN=

# Autenticación exclusiva entre Power Solar CRM y EcoFlow PR
# Debe ser diferente de GAS_TOKEN, CRM_QUOTE_TOKEN y AUTH_SECRET.
CRM_ECOFLOW_SERVICE_SECRET=
CRM_QUOTE_TOKEN=

# Modo de prueba
TEST_MODE=true
TEST_EMAIL_RECIPIENT=test-recipient@example.invalid

# URL pública
PUBLIC_BASE_URL=https://ecoflowpr.vercel.app
DEPLOYMENT_MODE=provisional

# Email / proveedor
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Información pública del consultor y empresa
CONSULTANT_NAME=Consultor EcoFlow
CONSULTANT_PHONE=000-000-0000
CONSULTANT_EMAIL=consultor@example.invalid
COMPANY_NAME=Power Solar
COMPANY_FULLNAME=Power Solar
COMPANY_LOCATION=Puerto Rico
COMPANY_WEBSITE=https://example.invalid

# Reglas
# - No reutilizar secretos entre servicios.
# - No usar valores de producción en Preview o Development.
# - Rotar cualquier valor que alguna vez haya aparecido en Git.
# - No escribir tokens, contraseñas, cookies ni credenciales JSON en este archivo.
